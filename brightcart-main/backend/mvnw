#!/bin/sh

set -e

BASE_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
WRAPPER_DIR="$BASE_DIR/.mvn/wrapper"
DIST_DIR="$WRAPPER_DIR/dists"
ARCHIVE_NAME="apache-maven-3.9.9-bin.zip"
ARCHIVE_PATH="$DIST_DIR/$ARCHIVE_NAME"
MAVEN_HOME="$DIST_DIR/apache-maven-3.9.9"
DOWNLOAD_URL="https://repo.maven.apache.org/maven2/org/apache/maven/apache-maven/3.9.9/$ARCHIVE_NAME"

mkdir -p "$DIST_DIR"

if [ ! -d "$MAVEN_HOME" ]; then
  if [ ! -f "$ARCHIVE_PATH" ]; then
    echo "Downloading Maven 3.9.9..."
    if command -v curl >/dev/null 2>&1; then
      curl -fsSL "$DOWNLOAD_URL" -o "$ARCHIVE_PATH"
    elif command -v wget >/dev/null 2>&1; then
      wget -q "$DOWNLOAD_URL" -O "$ARCHIVE_PATH"
    else
      echo "Error: curl or wget is required to download Maven." >&2
      exit 1
    fi
  fi

  EXTRACT_DIR="$DIST_DIR/.extract"
  rm -rf "$EXTRACT_DIR"
  mkdir -p "$EXTRACT_DIR"

  if command -v unzip >/dev/null 2>&1; then
    unzip -q "$ARCHIVE_PATH" -d "$EXTRACT_DIR"
  elif command -v jar >/dev/null 2>&1; then
    (
      cd "$EXTRACT_DIR"
      jar -xf "$ARCHIVE_PATH"
    )
  else
    echo "Error: unzip or jar is required to extract Maven." >&2
    exit 1
  fi

  rm -rf "$MAVEN_HOME"
  mv "$EXTRACT_DIR/apache-maven-3.9.9" "$MAVEN_HOME"
  rm -rf "$EXTRACT_DIR"
fi

exec "$MAVEN_HOME/bin/mvn" "$@"
